# GTFS API Configuration
GTFS_API_URL=https://gateway.carris.pt/gateway/gtfs/api/v2.11/GTFS/realtime/vehiclepositions
POLL_INTERVAL_SECONDS=30
GTFS_SSL_VERIFY=true
# Optional path to a custom CA bundle PEM file used to validate the GTFS endpoint.
# Example: /etc/ssl/certs/corporate-root-ca.pem
GTFS_CA_BUNDLE_PATH=

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
MAX_CONCURRENT_REDIS_OPERATIONS=100

# Vehicle Inactivity Timeout (in seconds)
# Vehicles inactive for longer than this will be hidden (marked inactive) in Redis
VEHICLE_INACTIVITY_TIMEOUT_SECONDS=180
# Trip Close Timeout (in seconds) - trip marked completed after vehicle inactive this long
TRIP_CLOSE_TIMEOUT_SECONDS=3600

# Application
APP_NAME=Carris Vehicle Ingestion
LOG_LEVEL=INFO
